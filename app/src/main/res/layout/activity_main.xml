<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context=".MainActivity">

    <!-- Thermal camera view -->
    <com.breyt.thermalcamera.ThermalView
        android:id="@+id/thermal_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/control_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status text (shown when camera not connected) -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/waiting_for_camera"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="@id/thermal_view"
        app:layout_constraintEnd_toEndOf="@id/thermal_view"
        app:layout_constraintStart_toStartOf="@id/thermal_view"
        app:layout_constraintTop_toTopOf="@id/thermal_view" />

    <!-- Control bar -->
    <LinearLayout
        android:id="@+id/control_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Colormap button with gradient preview -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp">
            <ImageButton
                android:id="@+id/btn_colormap"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="start"
                android:src="@drawable/ic_palette"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/desc_colormap" />
            <View
                android:id="@+id/colormap_preview"
                android:layout_width="4dp"
                android:layout_height="24dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginStart="48dp" />
        </FrameLayout>

        <!-- Rotate button with degree label and lock indicator -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp">
            <ImageButton
                android:id="@+id/btn_rotate"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="start"
                android:src="@drawable/ic_rotate"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/desc_rotate" />
            <ImageView
                android:id="@+id/icon_rotation_lock"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="32dp"
                android:layout_marginTop="2dp"
                android:src="@drawable/ic_lock"
                android:visibility="visible" />
            <TextView
                android:id="@+id/txt_rotation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:layout_marginStart="44dp"
                android:text="0°"
                android:textColor="@android:color/white"
                android:textSize="11sp" />
        </FrameLayout>

        <!-- Mirror -->
        <ImageButton
            android:id="@+id/btn_mirror"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_mirror"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desc_mirror"
            android:layout_marginEnd="12dp" />

        <!-- Screenshot -->
        <ImageButton
            android:id="@+id/btn_screenshot"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desc_screenshot"
            android:layout_marginEnd="12dp" />

        <!-- Overflow menu -->
        <ImageButton
            android:id="@+id/btn_overflow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_more"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desc_more" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
